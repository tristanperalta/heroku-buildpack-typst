#!/usr/bin/env bash

# Exit on error
set -euo pipefail

# Define directories provided by Heroku for the buildpack
BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

# Constants
DEFAULT_TYPST_VERSION="0.14.2"
TYPST_BASE_URL="https://github.com/typst/typst/releases/download"

# Read TYPST_VERSION from config vars
if [ -f "$ENV_DIR/TYPST_VERSION" ]; then
  TYPST_VERSION=$(cat "$ENV_DIR/TYPST_VERSION" | tr -d '[:space:]')
else
  TYPST_VERSION="$DEFAULT_TYPST_VERSION"
fi

# Detect architecture
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)  TYPST_ARCH="x86_64" ;;
  aarch64) TYPST_ARCH="aarch64" ;;
  *)       echo "  !     Unsupported architecture: $ARCH" >&2; exit 1 ;;
esac

ARCHIVE_NAME="typst-${TYPST_ARCH}-unknown-linux-musl"
DOWNLOAD_URL="${TYPST_BASE_URL}/v${TYPST_VERSION}/${ARCHIVE_NAME}.tar.xz"

# Cache logic: skip download if version matches
CACHE_VERSION_FILE="$CACHE_DIR/typst-version"
CACHED_BINARY="$CACHE_DIR/typst"

if [ -f "$CACHE_VERSION_FILE" ] && [ "$(cat "$CACHE_VERSION_FILE")" = "$TYPST_VERSION" ] && [ -f "$CACHED_BINARY" ]; then
  echo "-----> Using cached Typst v${TYPST_VERSION}"
else
  echo "-----> Downloading Typst v${TYPST_VERSION} for ${TYPST_ARCH}..."

  # Clean old cache
  rm -f "$CACHED_BINARY" "$CACHE_VERSION_FILE"

  curl -sSfL "$DOWNLOAD_URL" -o "$CACHE_DIR/${ARCHIVE_NAME}.tar.xz" || {
    echo "  !     Failed to download Typst v${TYPST_VERSION}" >&2
    echo "  !     URL: $DOWNLOAD_URL" >&2
    exit 1
  }

  # Extract binary
  tar -xJf "$CACHE_DIR/${ARCHIVE_NAME}.tar.xz" -C "$CACHE_DIR"
  cp "$CACHE_DIR/${ARCHIVE_NAME}/typst" "$CACHED_BINARY"
  chmod +x "$CACHED_BINARY"

  # Cleanup archive and extracted directory
  rm -rf "$CACHE_DIR/${ARCHIVE_NAME}.tar.xz" "$CACHE_DIR/${ARCHIVE_NAME}"

  echo "$TYPST_VERSION" > "$CACHE_VERSION_FILE"
  echo "-----> Typst v${TYPST_VERSION} downloaded successfully"
fi

# Install into slug
mkdir -p "$BUILD_DIR/.heroku/bin"
cp "$CACHED_BINARY" "$BUILD_DIR/.heroku/bin/typst"

# Set up PATH for runtime
mkdir -p "$BUILD_DIR/.profile.d"
echo 'export PATH="$PATH:/app/.heroku/bin"' > "$BUILD_DIR/.profile.d/typst.sh"

echo "-----> Typst v${TYPST_VERSION} installed"
